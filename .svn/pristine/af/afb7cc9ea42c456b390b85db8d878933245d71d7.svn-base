!if $wims_read_parm!=slib_header
!goto proc
!endif

slib_author=Sophie, Lemaire; Bernadette, Perrin-Riou

slib_parms=3\
,[data]\
1,mu\
1,sigma

 slib_example=[2,4,7] ,3,4\
 2,2,sqrt(2)\
 2,2,2\
 2,1,1
 !exit

:proc
slib_out=

!distribute item $wims_read_parm into slib_data,slib_mean,slib_var
!default slib_mean=1
!default slib_var=1
!! en fait c'est un Ècart type
slib_data=!declosing $slib_data

slib_out=
!for slib_x in $slib_data
  !if $slib_x > 0
    slib_out=!append item $[exp(-(log($slib_x)-$slib_mean)^2/(2*$slib_var^2))/($slib_x*$slib_var*(2*pi)^0.5)] to $slib_out
  !else
    slib_out=!append item 0 to $slib_out
  !endif
!next slib_x

slib_out=!trim $slib_out
