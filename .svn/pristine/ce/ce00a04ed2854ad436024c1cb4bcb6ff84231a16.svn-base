!if $wims_read_parm!=slib_header
  !goto proc
!endif

slib_parms=2\
,[data]\
,n

slib_author=Sophie, Lemaire; Bernadette, Perrin-Riou

slib_example=[0.2,0.4,0.7],5
slib_require=pari
!exit

:proc
slib_out=

!distribute item $wims_read_parm into slib_data,slib_a
slib_data=!declosing $slib_data

slib_test=!exec octave pkg list statistics
!if Installation iswordof $slib_test
  slib_out=!exec octave tinv([$slib_data],$slib_a)
!else
  !readproc slib/stat/commun stat
  !for slib_x in $(slib_data)
    slib_res=!exec pari statstudentinv($slib_a,$slib_x)
    slib_out=!append item $slib_res to $slib_out
  !next
!endif
slib_out=!words2items $slib_out
slib_out=!trim $slib_out
