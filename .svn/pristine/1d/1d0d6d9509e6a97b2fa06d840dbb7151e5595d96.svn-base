!read adm/title.phtml 3\
\
$wims_name_docslib (slib)

!set slib_detname=slibdet
!set slib_detailanchor=#slib
!if $slibdet!=$empty
  !set slibret=yes
!endif

!read slib/index.phtml

!if $slibret=yes
  !if $module=help/oefdoc
    !set wims_menu_items=!append line docslib,1,module=help/oefdoc&cmd=reply&special_parm=slib&subject=slib\
to $wims_menu_items
  !else
    !set wims_menu_items=!append line docslib,1,cmd=help&special_parm=slib&subject=slib\
to $wims_menu_items
  !endif
!endif
