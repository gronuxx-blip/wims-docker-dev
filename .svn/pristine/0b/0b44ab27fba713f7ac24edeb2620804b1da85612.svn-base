!set lang_exists=yes

!read adm/lang/sheetexam.phtml.$modu_lang
!set name_from=Ó partir du
!set name_student1=!nosubst Vous pouvez travailler sur cette feuille. Les notes seront prises en compte $fromdate jusqu'au $expday $expmon $expyear.
!set name_student2=Cette feuille a expirķ. Vous pouvez\
  encore y travailler mais vos notes ne seront plus prises en compte.
!set name_student3=Vous n'Ļtes pas autorisķ Ó consulter le contenu de cette feuille pour\
  l'instant. Veuillez contacter votre enseignant.
!set name_student5=Pour l'instant, votre enseignant a suspendu l'enregistrement des notes\
  sur cette feuille, mais vous pouvez continuer Ó travailler.

!set name_score=!nosubst $[$got] des $[$require] points requis, qualitķ
!set name_score2=!nosubst $[$require] points requis

!set name_scoreopen=L'enregistrement des notes est ouvert.
!set name_scoreclose=L'enregistrement des notes est fermķ.
!set name_scoreclosesup=L'arrĻt de l'enregistrement de la notation n'est pas autorisķ par votre enseignant.

!set name_textsource=Voici le fichier source de cette feuille. Vous pouvez l'importer \
  dans votre classe en utilisant un copier-coller.
!set name_answer_i=Rķponse Ó l'exercice

!set name_title=!nosubst $wims_name_sheet $wims_name_number$sh
!set name_exo=!defof name_exo in wimshome/public_html/scripts/oef/$modu_lang/names.proc
!set name_noprint=!defof name_noprint in oef/$modu_lang/names.proc
!set name_answers=!defof name_answers in oef/$modu_lang/names.proc

!distribute items niveau approximatif,durķe \
into name_level,name_duration

!set name_skillbullet=Compķtence(s) du livret concernķe(s)
!set name_indivsupervisor=Cette feuille est individualisķe Ó l'aide d'une variable technique.\
 Vous pouvez voir les diffķrentes formes de la feuille en fonction des valeurs possibles de la variable en utilisant le menu dķroulant ci-dessous.
!set name_choosevalue=Valeur affichķe
!set name_novalue=Sans valeur
!set name_msgusergroup=!nosubst Cette feuille dķpend de votre groupe de travail. Vous Ļtes dans le groupe $uservartechvalue.
!set name_msgusergroupempty=!nosubst Cette feuille dķpend de votre groupe de travail. Vous n'Ļtes dans aucun groupe.

!distribute items Nom,Prķnom,Classe into name_lastname,name_firstname,name_class
!set wims_name_latexuser=Version latex individualisķe
!set wims_name_printlatex=Version latex
